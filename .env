# ================================================================
#  AWS IoT Core
# ================================================================
# Encontre o endpoint em: AWS Console → IoT Core → Settings
AWS_IOT_ENDPOINT=a2ha7gc4jn594w-ats.iot.sa-east-1.amazonaws.com

# Caminhos dos certificados baixados do AWS IoT Core
# Coloque os arquivos dentro da pasta ./certs/
AWS_IOT_CERT=./certs/certificate.pem.crt
AWS_IOT_KEY=./certs/private.pem.key
AWS_IOT_CA=./certs/AmazonRootCA1.pem

# Client ID (pode ser qualquer nome único)
AWS_IOT_CLIENT_ID=iot-monitor-backend

# Tópico que o ESP32 publica
MQTT_TOPIC=sensor/dht11

# ================================================================
#  Mailtrap.io
#  Acesse: https://mailtrap.io → Inboxes → SMTP Settings → Nodemailer
# ================================================================
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=cole_aqui_seu_user
MAIL_PASS=cole_aqui_sua_senha
MAIL_FROM=iot-monitor@sistema.local
MAIL_TO=seu@email.com

# ================================================================
#  Motor de Regras
# ================================================================
# Limite de temperatura para disparar alerta (°C)
TEMP_THRESHOLD=28

# Janela da média móvel em milissegundos (padrão = 60000 = 1 min)
AVG_WINDOW_MS=60000

# Tempo sem dados para considerar falha (padrão = 60000 = 1 min)
TIMEOUT_MS=60000

# ================================================================
#  Servidor
# ================================================================
PORT=3001
